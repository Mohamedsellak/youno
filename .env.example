# Youno — Environment Configuration Template (.env.example)

# --- HUNTER.IO (Email Enrichment) ---
# Base API URL for Hunter.io services
HUNTER_API_BASE=https://api.hunter.io/v2
# API key for Hunter.io (optional)
HUNTER_API_KEY=your-hunter-api-key

# --- OPENROUTER (LLM Enrichment) ---
# Endpoint URL for the OpenRouter chat completions API
OPENROUTER_API_URL=https://openrouter.ai/api/v1/chat/completions
# API key for OpenRouter (required for AI enrichment)
OPENROUTER_API_KEY=your-openrouter-api-key
# LLM model identifier to query
OPENROUTER_MODEL=openai/gpt-oss-20b:free

# --- RATE LIMITING ---
# Maximum number of API requests allowed per IP address within the window
APP_RATE_LIMIT_MAX=10
# Sliding window duration in milliseconds (600000 ms = 10 minutes)
APP_RATE_LIMIT_WINDOW_MS=600000

# --- CACHE CONFIGURATION ---
# Local in-memory cache TTL in minutes
TTL_CACHE_MINUTES=5