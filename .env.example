# Environment Variables
# Copy this to .env.local and fill in your API keys

# OpenRouter API key (get one at https://openrouter.ai/keys)
OPENROUTER_API_KEY=sk-or-v1-your-key-here

# OpenRouter model to use (free models available)
# Default: google/gemma-4-31b-it:free
# Alternatives: deepseek/deepseek-v4-flash:free, meta-llama/llama-3.3-70b-instruct:free
OPENROUTER_MODEL=google/gemma-4-31b-it:free

# Hunter.io API key (get one at https://hunter.io/api-keys)
# Optional: the app works without it (graceful degradation)
HUNTER_API_KEY=your-hunter-api-key-here

# Optional: Rate limiting configuration
# APP_RATE_LIMIT_MAX=10
# APP_RATE_LIMIT_WINDOW_MS=600000
